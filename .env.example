# ─────────────────────────────────────────────────────────────
# Galindo BJJ — environment variables
# Copy this file to `.env.local` and fill in your Supabase values.
# Never commit `.env.local` (it is gitignored).
# ─────────────────────────────────────────────────────────────

# Supabase project URL, e.g. https://abcdefgh.supabase.co
# Find it in: Supabase dashboard → Project Settings → Data API
NEXT_PUBLIC_SUPABASE_URL=

# Supabase "anon" public key (safe to expose in the browser).
# Row Level Security protects the data — see supabase/migrations.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: service-role key. ONLY used by the seed script (server side).
# NEVER expose this in the browser or commit it. Leave blank in production.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL (used for canonical links / metadata). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://galindobjj.es
